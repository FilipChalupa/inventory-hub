# Server
PORT=3001
NODE_ENV=development

# Database (SQLite file path)
DATABASE_URL=file:./data/app.db

# Auth (Google OAuth — optional; without it použij dev login na /login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:3001/auth/google/callback

# Public URL for QR codes and OAuth redirects
PUBLIC_APP_URL=http://localhost:5173

# Uploads
UPLOAD_DIR=./data/uploads
UPLOAD_MAX_BYTES=5242880

# SMTP (optional; falls back to console logger when unset)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Inventory Hub <no-reply@example.com>"

# Remote MCP server (optional). The canonical resource URL MCP clients connect
# to; tokens are audience-bound to it. Defaults to PUBLIC_APP_URL + /mcp.
# Must be HTTPS in production. Requires Google OAuth to be configured (the MCP
# authorize flow reuses the existing login).
# MCP_BASE_URL=https://your-domain.example/mcp
# MCP_ACCESS_TOKEN_TTL=3600
# MCP_REFRESH_TOKEN_TTL=2592000
